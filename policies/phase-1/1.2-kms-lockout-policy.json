{
  "Version": "2012-10-17",
  "Id": "deliberate-lockout-demo",
  "Statement": [
    {
      "Sid": "AllowAppRoleToUseKeyForData",
      "Effect": "Allow",
      "Principal": { "AWS": "arn:aws:iam::<ACCOUNT_B_ID>:role/AppEncryptRole" },
      "Action": ["kms:Encrypt", "kms:Decrypt", "kms:GenerateDataKey", "kms:DescribeKey"],
      "Resource": "*"
    }
  ]
}
